generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DeploymentMode {
  template
  custom
}

enum DeploymentStatus {
  accepted
  running
  succeeded
  failed
}

model Deployment {
  id             String           @id @default(cuid())
  mode           DeploymentMode
  status         DeploymentStatus @default(accepted)
  submittedBy    String
  tenantId       String
  subscriptionId String
  resourceGroup  String
  payload        Json
  bicepOutput    String?
  errorMessage   String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}
