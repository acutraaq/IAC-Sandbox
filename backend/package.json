    "jose": "^5.0.0",
    "@azure/arm-resources": "^5.2.0",
    "@azure/identity": "^4.4.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "pino-pretty": "^13.0.0",
    "prisma": "^6.0.0",
    "vitest": "^2.0.0"
  }
