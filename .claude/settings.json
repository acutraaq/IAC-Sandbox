{
  "permissions": {
    "allow": [
      "Bash(npx vitest *)",
      "Skill(commit-commands:commit-push-pr)",
      "Skill(commit-commands:commit-push-pr:*)",
      "WebFetch(domain:microsoft.github.io)",
      "mcp__plugin_microsoft-docs_microsoft-learn__microsoft_docs_search",
      "Bash(npm ls *)",
      "Bash(npm test *)",
      "Bash(xargs grep *)",
      "Bash(python .claude/hooks/secret-leak-guard.py)",
      "Bash(bash .claude/hooks/session-start.sh)",
      "Bash(git check-ignore *)",
      "Bash(GIT_SSL_NO_VERIFY=true git pull origin main)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/secret-leak-guard.py"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-start.sh"
          }
        ]
      }
    ]
  }
}
